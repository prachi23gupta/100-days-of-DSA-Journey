#include <iostream>
#include <vector>
using namespace std;

// Optimal Solution

// Best time to buy and sell stocks - maximise the profit
// but order is impotant - we have to buy before we sell

int main(){

    vector <int> prices = {5, 10, 2, 8};

    int n = prices.size();
    int profit = 0;
    int minPrice = prices[0];
    int costPrice = 0;

    for(int i = 0; i < n; i++){
        costPrice = prices[i] - minPrice;
        profit = max(profit, costPrice);
        minPrice = min(minPrice, prices[i]); // important 🔥
    }
    cout << "Maximum profit: " << profit << endl;

    return 0;
}

// Time Complexity: O(n)
// Space Complexity: O(1)
